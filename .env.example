# ─────────────────────────────────────────
# AI Hiring Assistant — Environment Variables
# Copy to .env and fill in all values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────

# ── Database ─────────────────────────────
# Individual vars used by docker-compose; DATABASE_URL assembled from these
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hiring_assistant
# Full URL used by backend directly (for local dev outside Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hiring_assistant

# ── Redis ────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic (LLM) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (Embeddings) ──────────────────
OPENAI_API_KEY=sk-...

# ── Clerk (Auth) ─────────────────────────
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Cloudflare R2 (File Storage) ─────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=hiring-assistant-cvs
R2_PUBLIC_URL=https://...r2.dev

# ── Observability ────────────────────────
SENTRY_DSN=
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── App ──────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-min-32-chars
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── hirematch service ─────────────────────
HIREMATCH_API_KEY=dev-secret-key
# Vite bakes these into the browser bundle at build time
VITE_HIREMATCH_API_URL=http://localhost:8001
VITE_HIREMATCH_API_KEY=dev-secret-key

# ── Network Trust Gate (tunable thresholds) ───
TRUST_GATE_SCORE_THRESHOLD=75
TRUST_GATE_CONFIDENCE_THRESHOLD=0.8
TRUST_GATE_DIVERSITY_THRESHOLD=0.15

# ── Worker ───────────────────────────────
WORKER_CONCURRENCY=4
LLM_MAX_RETRIES=3
