# Database
DATABASE_URL=postgresql+asyncpg://hermes:hermes_dev@localhost:5432/hermes_hiring
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=hermes
S3_SECRET_KEY=hermes_dev
S3_CV_BUCKET=hermes-cvs
S3_MODEL_OUTPUTS_BUCKET=hermes-model-outputs

# LLM (OpenAI compatible)
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_EMBEDDING_MODEL=text-embedding-3-small

# Hermes Orchestrator
HERMES_MATCHING_TIMEOUT=8.0
HERMES_MAX_RETRIES=3
HERMES_AGENT_BASE_URL=http://localhost:8000

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=hermes-hiring

# Logging
LOG_LEVEL=INFO
